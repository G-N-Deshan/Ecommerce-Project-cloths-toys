# ── Local Development ──
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Local MySQL (used when DATABASE_URL is not set)
DB_NAME=myproject
DB_USER=root
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=3306

